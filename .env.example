# ── Database ─────────────────────────────────────
DB_PASSWORD=your_db_password_here

# ── Redis ────────────────────────────────────────
REDIS_PASSWORD=your_redis_password_here

# ── Shopify ──────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ── Daraz ────────────────────────────────────────
DARAZ_APP_KEY=
DARAZ_APP_SECRET=

# ── Token Vault ──────────────────────────────────
VAULT_MASTER_KEY=generate_a_32_char_random_key_here

# ── AI / LLM ────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Courier APIs ─────────────────────────────────
TCS_API_KEY=
LEOPARDS_API_KEY=
LEOPARDS_API_PASSWORD=
POSTEX_TOKEN=
TRAX_API_KEY=
BLUEEX_USERNAME=
BLUEEX_PASSWORD=

# ── WhatsApp Business API ────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── MinIO (Object Storage) ───────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── App URLs ─────────────────────────────────────
APP_URL=http://localhost
WS_URL=ws://localhost:3000

# ── NextAuth ─────────────────────────────────────
NEXTAUTH_SECRET=generate_a_random_secret_here

# ── Google OAuth (Seller Login) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── JWT RS256 Keys ───────────────────────────────
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public.pem

# ── Trax ─────────────────────────────────────────
TRAX_USERNAME=
